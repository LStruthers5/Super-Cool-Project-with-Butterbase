# ── Butterbase ───────────────────────────────────────────────────────────────
# Sign up at dashboard.butterbase.ai — promo code BUILDER0613 for $20 credit.
# After creating an app, find these values in Settings → API.
BUTTERBASE_APP_ID=
BUTTERBASE_API_URL=
BUTTERBASE_ANON_KEY=

# Butterbase also powers the model gateway (Claude/GPT/Gemini via one key).
# Same key as above works for /api/source-college if your plan includes AI credits.
BUTTERBASE_API_KEY=

# ── Exa ──────────────────────────────────────────────────────────────────────
# Second-source verification for the college sourcing agent (optional).
EXA_API_KEY=

# ── Evermind (EverOS) ────────────────────────────────────────────────────────
# Local-first memory OS. Install: pip install everos && everos server start
# Defaults to http://127.0.0.1:8000 — override if running on a different port.
NEXT_PUBLIC_EVERMIND_URL=http://127.0.0.1:8000
